    {
      "id": 8,
      "title": "CPU Utilization %",
      "description": "CPU utilization as percentage of reserved (utilized / reserved × 100)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 15 },
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "ClusterName": ["puzzleboss"], "ServiceName": ["puzzleboss"] },
          "matchExact": true, "metricEditorMode": 0,
          "metricName": "CpuUtilized",
          "metricQueryType": 0,
          "namespace": "ECS/ContainerInsights",
          "period": "300", "queryMode": "Metrics", "refId": "pb_util",
          "region": "us-east-1", "statistic": "Average", "label": "", "hide": true
        },
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "ClusterName": ["puzzleboss"], "ServiceName": ["puzzleboss"] },
          "matchExact": true, "metricEditorMode": 0,
          "metricName": "CpuReserved",
          "metricQueryType": 0,
          "namespace": "ECS/ContainerInsights",
          "period": "300", "queryMode": "Metrics", "refId": "pb_res",
          "region": "us-east-1", "statistic": "Average", "label": "", "hide": true
        },
        {
          "datasource": { "type": "__expr__", "uid": "__expr__" },
          "expression": "$pb_util / $pb_res * 100",
          "type": "math",
          "refId": "puzzleboss",
          "hide": false
        },
