    {
      "id": 5,
      "title": "Running Tasks",
      "description": "Running task count per ECS service over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 6 },
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "ClusterName": ["puzzleboss"], "ServiceName": ["puzzleboss"] },
