          "metricQueryType": 0,
          "namespace": "ECS/ContainerInsights",
          "period": "60",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "us-east-1",
          "statistic": "Average",
          "label": "puzzleboss deploys"
        },
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "ClusterName": ["puzzleboss"], "ServiceName": ["mediawiki"] },
          "matchExact": true,
          "metricEditorMode": 0,
          "metricName": "DeploymentCount",
          "metricQueryType": 0,
          "namespace": "ECS/ContainerInsights",
          "period": "60",
          "queryMode": "Metrics",
          "refId": "B",
          "region": "us-east-1",
          "statistic": "Average",
