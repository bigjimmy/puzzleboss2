{
  "__inputs": [
    {
      "name": "DS_CLOUDWATCH",
      "label": "CloudWatch",
      "description": "AWS CloudWatch datasource with ECS Container Insights",
      "type": "datasource",
      "pluginId": "cloudwatch",
      "pluginName": "CloudWatch"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "cloudwatch", "name": "CloudWatch", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "ECS Fargate fleet health: task counts, CPU, memory, network per service",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Service Health",
      "type": "row"
    },
    {
      "id": 1,
      "title": "puzzleboss",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "ClusterName": ["puzzleboss"], "ServiceName": ["puzzleboss"] },
          "matchExact": true,
          "metricEditorMode": 0,
          "metricName": "RunningTaskCount",
          "metricQueryType": 0,
          "namespace": "ECS/ContainerInsights",
          "period": "60",
          "queryMode": "Metrics",
          "refId": "running",
          "region": "us-east-1",
          "statistic": "Average",
          "label": "Running"
        },
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "ClusterName": ["puzzleboss"], "ServiceName": ["puzzleboss"] },
          "matchExact": true,
          "metricEditorMode": 0,
          "metricName": "DesiredTaskCount",
          "metricQueryType": 0,
          "namespace": "ECS/ContainerInsights",
          "period": "60",
          "queryMode": "Metrics",
          "refId": "desired",
          "region": "us-east-1",
          "statistic": "Average",
          "label": "Desired",
          "hide": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [],
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      }
    },
