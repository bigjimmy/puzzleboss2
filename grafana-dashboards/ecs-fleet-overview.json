          "period": "60",
          "queryMode": "Metrics",
          "refId": "C",
          "region": "us-east-1",
          "statistic": "Average",
          "label": "bigjimmy"
        },
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "ClusterName": ["puzzleboss"], "ServiceName": ["memcache"] },
          "matchExact": true,
          "metricEditorMode": 0,
          "metricName": "RunningTaskCount",
          "metricQueryType": 0,
          "namespace": "ECS/ContainerInsights",
          "period": "60",
          "queryMode": "Metrics",
          "refId": "D",
          "region": "us-east-1",
          "statistic": "Average",
          "label": "memcache"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Tasks",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true,
            "stacking": { "mode": "none" }
          },
          "decimals": 0,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
