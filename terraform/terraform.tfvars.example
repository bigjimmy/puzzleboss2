# terraform.tfvars.example — Copy to terraform.tfvars and fill in real values
#
# cp terraform.tfvars.example terraform.tfvars
# vi terraform.tfvars
#
# terraform.tfvars is gitignored (contains secrets).

# --- General ---
aws_region   = "us-east-1"
environment  = "prod"
project_name = "puzzleboss"

# --- DNS / SSL ---
domain_name     = "importanthuntpoll.org"
route53_zone_id = "Z06231973NK0NP1OVRDZT"

# --- Network (existing default VPC) ---
vpc_id     = "vpc-b5d8ffcf"
subnet_ids = ["subnet-82a278cf", "subnet-a71106fb"]  # us-east-1a, us-east-1b

# --- RDS (existing — will be imported) ---
rds_instance_identifier = "wind-up-birds"
rds_instance_class      = "db.t4g.small"
rds_allocated_storage   = 20
rds_database_name       = "puzzleboss"
rds_username            = "puzzleboss"
rds_password            = "CHANGE_ME"  # Your actual RDS password

# --- ECS — Puzzleboss (idle mode defaults, bump for hunt) ---
puzzleboss_cpu              = 1024   # 1 vCPU
puzzleboss_memory           = 3072   # 3 GB
puzzleboss_desired_count    = 1      # Set to 2 for hunt
puzzleboss_gunicorn_workers = 4      # 4 workers × 2 tasks = 8 total during hunt

# --- ECS — MediaWiki ---
mediawiki_cpu           = 512    # 0.5 vCPU
mediawiki_memory        = 1024   # 1 GB
mediawiki_desired_count = 1

# --- ECS — BigJimmy (idle mode, bump for hunt) ---
bigjimmy_cpu    = 256    # 0.25 vCPU idle, 512 for hunt
bigjimmy_memory = 512    # 512 MB idle, 1024 for hunt

# --- ECS — Memcache ---
memcache_cpu    = 256    # 0.25 vCPU
memcache_memory = 512    # 512 MB

# --- Observability EC2 ---
observability_instance_type = "t4g.small"
observability_volume_size   = 30
ssh_key_name                = ""    # Your EC2 key pair name
ssh_allowed_cidrs           = []    # e.g., ["203.0.113.0/32"] for your IP
